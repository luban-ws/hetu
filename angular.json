{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "metrogit": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src/renderer",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "out/renderer",
            "index": "src/renderer/index.html",
            "main": "src/renderer/main.ts",
            "polyfills": "src/renderer/polyfills.ts",
            "tsConfig": "tsconfig.json",
            "assets": [
              "src/renderer/assets",
              "src/renderer/favicon.ico"
            ],
            "styles": [
              "src/renderer/bootstrap.min.css",
              "src/renderer/styles.scss"
            ],
            "scripts": [],
            "allowedCommonJsDependencies": [
              "moment",
              "angular2-notifications",
              "angular2-hotkeys"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10MB",
                  "maximumError": "12MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kB",
                  "maximumError": "10kB"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/renderer/environments/environment.ts",
                  "with": "src/renderer/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "metrogit:build:production"
            },
            "development": {
              "buildTarget": "metrogit:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}