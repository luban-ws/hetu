{
  "name": "metrogit",
  "version": "0.4.0",
  "description": "Metro themed git UI",
  "main": "app/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "test": "ng test --config=karma-ci.conf.js",
    "electron:pack": "electron-builder --dir",
    "electron:build": "npm run build:prod && electron-builder --publish never",
    "electron:window": "npm run build:prod && electron-builder build --publish always",
    "electron:linux": "npm run build:prod && electron-builder build --linux --publish always",
    "electron:mac": "npm run build:prod && electron-builder build --mac --publish always",
    "ng": "ng",
    "build:prod": "ng build --configuration production",
    "ng:serve": "ng serve",
    "build": "ng build --configuration production --base-href /$ROOT/app/frontend/dist/",
    "ng:test": "ng test",
    "ng:lint": "ng lint",
    "ng:e2e": "ng e2e"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yamazaki93/MetroGit.git"
  },
  "author": {
    "name": "Michael Lu",
    "email": "michaellu@rhodiumcode.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@angular-devkit/build-angular": "^13.3.11",
    "@angular/cli": "^13.3.11",
    "@angular/compiler-cli": "^13.4.0",
    "@angular/language-service": "^13.4.0",
    "@types/jasmine": "~3.3.12",
    "@types/jasminewd2": "~2.0.6",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^14.18.63",
    "codelyzer": "^6.0.2",
    "electron": "^13.6.9",
    "electron-builder": "^20.39.0",
    "electron-rebuild": "^3.2.9",
    "jasmine-core": "~3.3.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~2.2.0",
    "karma-coverage-istanbul-reporter": "^2.0.5",
    "karma-jasmine": "~2.0.1",
    "karma-jasmine-html-reporter": "^1.4.0",
    "protractor": "~7.0.0",
    "ts-node": "~8.0.3",
    "tslint": "~5.14.0",
    "typescript": "~4.6.4"
  },
  "dependencies": {
    "@angular/animations": "^13.4.0",
    "@angular/cdk": "^7.3.6",
    "@angular/common": "^13.4.0",
    "@angular/compiler": "^13.4.0",
    "@angular/core": "^13.4.0",
    "@angular/forms": "^13.4.0",
    "@angular/platform-browser": "^13.4.0",
    "@angular/platform-browser-dynamic": "^13.4.0",
    "@angular/router": "^13.4.0",
    "ajv": "^6.12.6",
    "angular2-hotkeys": "^2.4.0",
    "animate.css": "^4.1.1",
    "axios": "^0.27.2",
    "core-js": "2.6.1",
    "d3": "^7.9.0",
    "electron-updater": "^4.0.6",
    "get-folder-size": "^2.0.1",
    "isomorphic-git": "^1.33.1",
    "keytar": "^7.9.0",
    "moment": "^2.30.1",
    "mousetrap": "^1.6.5",
    "ngx-contextmenu": "^5.4.0",
    "read-last-line": "^1.1.0",
    "rxjs": "^6.6.7",
    "rxjs-compat": "^6.4.0",
    "uuid": "^8.3.2",
    "zone.js": "^0.11.8"
  },
  "volta": {
    "node": "18.20.8"
  }
}