{
  "name": "hetu",
  "version": "0.5.0",
  "private": true,
  "description": "Hetu monorepo \u2014 subway-map style Git client",
  "repository": {
    "type": "git",
    "url": "https://github.com/luban-ws/hetu.git"
  },
  "author": {
    "name": "Michael Lu",
    "email": "michaellu@rhodiumcode.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "desktop:dev": "pnpm --filter @luban-ws/desktop dev",
    "desktop:build": "pnpm --filter @luban-ws/desktop build",
    "desktop:tauri:dev": "pnpm --filter @luban-ws/desktop tauri:dev",
    "desktop:tauri:build": "pnpm --filter @luban-ws/desktop tauri:build",
    "site:dev": "pnpm --filter @luban-ws/site dev",
    "site:build": "pnpm --filter @luban-ws/site build"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "electron",
      "esbuild",
      "lmdb",
      "lzma-native",
      "msgpackr-extract",
      "nodegit",
      "sharp"
    ]
  }
}
