{
  "name": "hetu",
  "version": "0.5.0",
  "description": "Hetu - subway-map style Git client",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "npm run build && electron .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build && tauri build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:angular": "vitest run --config vitest.angular.config.mjs",
    "test:angular:coverage": "vitest run --config vitest.angular.config.mjs --coverage ",
    "electron:pack": "electron-builder --dir",
    "electron:build": "npm run build && electron-builder --publish never",
    "electron:window": "npm run build && electron-builder build --publish always",
    "electron:linux": "npm run build && electron-builder build --linux --publish always",
    "electron:mac": "npm run build && electron-builder build --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/systembugtj/hetu.git"
  },
  "author": {
    "name": "Michael Lu",
    "email": "michaellu@rhodiumcode.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^1.20.2",
    "@analogjs/vitest-angular": "^1.20.2",
    "@angular-devkit/build-angular": "^20.2.2",
    "@angular/cli": "^20.2.2",
    "@angular/compiler-cli": "^20.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@types/log4js": "^0.0.33",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^20.19.5",
    "electron": "^38.1.2",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^4.0.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@angular/animations": "^20.2.4",
    "@angular/cdk": "^20.2.2",
    "@angular/common": "^20.2.4",
    "@angular/compiler": "^20.2.4",
    "@angular/core": "^20.2.4",
    "@angular/forms": "^20.2.4",
    "@angular/localize": "^20.2.4",
    "@angular/platform-browser": "^20.2.4",
    "@angular/platform-browser-dynamic": "^20.2.4",
    "@angular/router": "^20.2.4",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ngneat/hotkeys": "^4.1.0",
    "@perfectmemory/ngx-contextmenu": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "ajv": "^6.12.6",
    "angular2-hotkeys": "^2.4.0",
    "angular2-notifications": "^16.0.1",
    "animate.css": "^4.1.1",
    "axios": "^0.27.2",
    "core-js": "2.6.1",
    "d3": "^7.9.0",
    "electron-updater": "^4.0.6",
    "get-folder-size": "^2.0.1",
    "isomorphic-git": "^1.33.1",
    "log4js": "^6.9.1",
    "moment": "^2.30.1",
    "mousetrap": "^1.6.5",
    "ngx-toastr": "^14.3.0",
