{
  "name": "explorasa-git",
  "version": "0.4.0",
  "description": "Metro themed git UI",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "npm run build && electron .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:angular": "vitest --config vitest.angular.config.js",
    "test:angular:run": "vitest run --config vitest.angular.config.js",
    "electron:pack": "electron-builder --dir",
    "electron:build": "npm run build && electron-builder --publish never",
    "electron:window": "npm run build && electron-builder build --publish always",
    "electron:linux": "npm run build && electron-builder build --linux --publish always",
    "electron:mac": "npm run build && electron-builder build --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/systembugtj/explorasa-git.git"
  },
  "author": {
    "name": "Michael Lu",
    "email": "michaellu@rhodiumcode.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^1.20.2",
    "@analogjs/vitest-angular": "^1.20.2",
    "@angular-devkit/build-angular": "^20.2.2",
    "@angular/cli": "^20.2.2",
    "@angular/compiler-cli": "^20.2.4",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^14.18.63",
    "electron": "^13.6.9",
    "electron-builder": "^20.39.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^3.1.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@angular/animations": "^20.2.4",
    "@angular/cdk": "^20.2.2",
    "@angular/common": "^20.2.4",
    "@angular/compiler": "^20.2.4",
    "@angular/core": "^20.2.4",
    "@angular/forms": "^20.2.4",
    "@angular/platform-browser": "^20.2.4",
    "@angular/platform-browser-dynamic": "^20.2.4",
    "@angular/router": "^20.2.4",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ngneat/hotkeys": "^4.1.0",
    "@perfectmemory/ngx-contextmenu": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "ajv": "^6.12.6",
    "angular2-hotkeys": "^2.4.0",
    "angular2-notifications": "^16.0.1",
    "animate.css": "^4.1.1",
    "axios": "^0.27.2",
    "core-js": "2.6.1",
    "d3": "^7.9.0",
    "electron-updater": "^4.0.6",
    "get-folder-size": "^2.0.1",
    "keytar": "^7.9.0",
    "moment": "^2.30.1",
    "mousetrap": "^1.6.5",
    "ngx-toastr": "^14.3.0",
    "radash": "^12.1.1",
    "read-last-line": "^1.1.0",
    "rxjs": "^6.6.7",
    "rxjs-compat": "^6.4.0",
    "uuid": "^8.3.2",
    "wasm-git": "^0.0.13",
    "zone.js": "^0.15.1"
  },
  "volta": {
    "node": "20.19.5"
  }
}
