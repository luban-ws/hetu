---
/**
 * Feature grid — four key features with icons and descriptions.
 * Each feature card has a subway-line colored accent strip on top.
 */

const FEATURES = [
  {
    title: 'Subway-Map Visualization',
    description:
      'Branches and commits rendered as an intuitive metro map. See the entire history at a glance — merges, rebases, and parallel work all clearly visible.',
    icon: 'map',
    color: 'var(--color-line-blue)',
    screenshot: '/screenshots/main-view.png',
  },
  {
    title: 'Inline Diff Viewer',
    description:
      'Review changes without leaving the app. Toggle between hunk and file views with syntax-highlighted diffs and clear addition/removal markers.',
    icon: 'diff',
    color: 'var(--color-line-green)',
    screenshot: '/screenshots/diff-view.png',
  },
  {
    title: 'JIRA Integration',
    description:
      'Native JIRA panel shows issue details, subtasks, and comments alongside your commits. Link work items directly from your Git workflow.',
    icon: 'jira',
    color: 'var(--color-line-orange)',
    screenshot: '/screenshots/jira-integration.png',
  },
  {
    title: 'CI Build Status',
    description:
      'AppVeyor build results integrated per-commit. See pass/fail indicators right on the map with on-demand log downloads.',
    icon: 'ci',
    color: 'var(--color-line-purple)',
    screenshot: '/screenshots/ci-integration.png',
  },
] as const;

const ICON_PATHS: Record<string, string> = {
  map: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  diff: 'M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2',
  jira: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  ci: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<section id="features" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Section header -->
    <div class="text-center">
      <h2
        class="text-3xl font-bold tracking-tight md:text-4xl"
        style="font-family: var(--font-display);"
      >
        Everything you need in a Git client
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg" style="color: var(--color-text-secondary);">
        Designed for developers who want clarity and speed — not just another terminal wrapper.
      </p>
    </div>

    <!-- Feature cards -->
    <div class="mt-16 grid gap-6 md:grid-cols-2">
      {FEATURES.map(({ title, description, icon, color, screenshot }) => (
        <div
          class="group relative overflow-hidden rounded-2xl border transition-all duration-300 hover:border-transparent hover:shadow-xl hover:shadow-black/30"
          style={`border-color: var(--color-border); background: var(--color-surface);`}
        >
          {/* Colored top accent bar */}
          <div class="h-1" style={`background: ${color};`} />

          <div class="p-8">
            <div class="flex items-start gap-4">
              <div
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg"
                style={`background: color-mix(in srgb, ${color} 15%, transparent);`}
              >
                <svg
                  class="h-5 w-5"
                  fill="none"
                  stroke={color}
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={ICON_PATHS[icon]} />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold">{title}</h3>
                <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                  {description}
                </p>
              </div>
            </div>

            {/* Screenshot preview */}
            <div class="mt-6 overflow-hidden rounded-lg border" style="border-color: var(--color-border);">
              <img
                src={screenshot}
                alt={`${title} screenshot`}
                class="w-full transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
