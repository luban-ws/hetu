---
const NAV_ITEMS = [
  { label: 'Features', href: '/#features' },
  { label: 'Docs', href: '/docs/getting-started' },
  { label: 'Blog', href: '/blog' },
];

const GITHUB_URL = 'https://github.com/luban-ws/hetu';
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur-xl transition-colors"
  style="background: color-mix(in srgb, var(--color-void) 85%, transparent); border-color: var(--color-border);"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <svg viewBox="0 0 48 48" class="h-8 w-8" aria-hidden="true">
        <rect width="48" height="48" rx="10" fill="var(--color-surface)" />
        <circle cx="14" cy="14" r="4" fill="var(--color-line-blue)" />
        <circle cx="24" cy="24" r="4" fill="var(--color-line-green)" />
        <circle cx="34" cy="34" r="4" fill="var(--color-line-orange)" />
        <line x1="14" y1="14" x2="24" y2="24" stroke="var(--color-line-blue)" stroke-width="2.5" stroke-linecap="round" />
        <line x1="24" y1="24" x2="34" y2="34" stroke="var(--color-line-green)" stroke-width="2.5" stroke-linecap="round" />
        <line x1="14" y1="14" x2="14" y2="34" stroke="var(--color-line-blue)" stroke-width="2.5" stroke-linecap="round" />
        <circle cx="14" cy="34" r="4" fill="var(--color-line-blue)" />
      </svg>
      <span
        class="text-xl font-bold tracking-tight transition-colors group-hover:text-[var(--color-accent)]"
        style="font-family: var(--font-display);"
      >
        Hetu
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden items-center gap-8 md:flex">
      {NAV_ITEMS.map(({ label, href }) => (
        <a
          href={href}
          class="text-sm font-medium transition-colors hover:text-[var(--color-accent)]"
          style="color: var(--color-text-secondary);"
        >
          {label}
        </a>
      ))}
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-medium transition-all hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        style="border-color: var(--color-border); color: var(--color-text-secondary);"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
        </svg>
        GitHub
      </a>
    </nav>
  </div>
</header>
