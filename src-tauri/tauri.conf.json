{
  "productName": "Hetu",
  "version": "0.5.0",
  "identifier": "com.rhodiumcode.hetu",
  "build": {
    "beforeDevCommand": "npx vite dev --config vite.tauri.config.mjs",
    "beforeBuildCommand": "npx vite build --config vite.tauri.config.mjs",
    "devUrl": "http://localhost:5180",
    "frontendDist": "../out/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hetu",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
